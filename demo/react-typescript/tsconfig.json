{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist/",
        "sourceMap": true,
        "strict": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "target": "es6",
        "jsx": "react",
        "lib": ["DOM", "DOM.Iterable", "ES6", "ES2021.String", "ScriptHost"],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": ["./src/**/*"],
    "exclude": []
}
