{
    "name": "@adadapted/js-sdk",
    "description": "The AdAdapted JS SDK.",
    "version": "0.0.0-development",
    "main": "src/index.js",
    "module": "src/index.js",
    "types": "src/index.d.ts",
    "files": [
        "src/index.js",
        "src/index.d.ts"
    ],
    "scripts": {
        "prettier-fix": "prettier --write \"*.{ts,tsx,js,jsx,json,css,scss,md}\" \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
        "lint": "eslint --version && eslint ./",
        "compile": "tsc --version && tsc --project tsconfig.json --noEmit --noErrorTruncation --pretty",
        "test-coverage": "rm -rf coverage && jest --version && jest --coverage",
        "enable-pre-commit": "pre-commit install",
        "test": "jest --version && jest",
        "prettier": "prettier --list-different \"*.{ts,tsx,js,jsx,json,css,scss,md}\" \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
        "npm-check-outdated": "npm outdated",
        "check-peer-dependencies": "npx check-peer-dependencies --npm",
        "update-packages-semver-safe": "npm update",
        "update-packages-latest-available": "npx npm-check-updates -u",
        "install-packages": "npm install",
        "audit-fix-packages": "npm audit fix"
    },
    "keywords": [
        "javascript",
        "adadapted",
        "web",
        "sdk",
        "ad",
        "ads"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/adadaptedinc/adadapted-js-sdk"
    },
    "author": "Jeramy Usher <jusher@adadapted.com> (https://github.com/adadaptedinc/adadapted-js-sdk)",
    "license": "AdAdapted Platform License",
    "bugs": {
        "url": "https://github.com/adadaptedinc/adadapted-js-sdk/issues"
    },
    "homepage": "https://docs.adadapted.com/#/",
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@peculiar/webcrypto": "^1.5.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/user-event": "^14.6.1",
        "@types/jsdom": "^28.0.1",
        "eslint": "^10.0.0",
        "eslint-plugin-import-x": "^4.17.1",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-jsdoc": "^63.0.0",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "globals": "^17.5.0",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jest-util": "^30.3.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.5.3",
        "ts-jest": "^29.3.2",
        "ts-node": "^10.9.2",
        "type-zoo": "^3.4.1",
        "typescript": "^6.0.3"
    }
}
